.post-body .image-caption, .post-body .figure .caption {
    font-size: 14px;
    font-weight: 400;
	margin: -15px auto 15px;
}

// 右下角返回顶部按钮样式
.back-to-top {
    line-height: 1.5;
    padding-right: 5px;
    padding-left: 5px;
    padding-top: 2.5px;
    padding-bottom: 2.5px;
    background-color: rgba(161, 102, 171, 0.75);
    border-radius: 5px;
    box-shadow: 0px 0px 10px 0px rgba(0, 0, 0, 0.35);
}
.back-to-top.back-to-top-on {
    bottom: 10px;
}
// 页面最顶部的横线
.headband {
    height: 1.5px;
    background-image: linear-gradient(90deg, #F79533 0%, #F37055 15%, #EF4E7B 30%, #A166AB 44%, #5073B8 58%, #1098AD 72%, #07B39B 86%, #6DBA82 100%);
}
// 页面顶部行高
.header {
    line-height: 1.5;
}

// 页面留白更改
.header-inner {
    padding-top: 20px;
    padding-bottom: 20px;
}
.posts-expand {
    padding-top: 80px;
}
.posts-expand .post-meta {
    margin: 5px 0px 0px 0px;
}

// 顶栏宽度

.container {
	display: flex;
	min-height: 100vh;
	flex-flow: column;
}


// 站点子标题
.site-subtitle{
    margin: 0px;
    font-size: 16px;
    letter-spacing: 1px;
    padding-bottom: 3px;
    font-weight: bold;
    color: rgb(255, 255, 255);
    border-bottom-width: 3px;
    border-bottom-style: solid;
    border-bottom-color: rgb(161, 102, 171);
}
// 菜单
.menu {
    text-align: center;
    margin-top: 0px;
    margin-bottom: 0px;
    padding: 5px;
    background-color: rgba(255, 255, 255, 0.75);
    box-shadow: 0px 10px 10px 0px rgba(0, 0, 0, 0.15);
}
// 菜单超链接字体大小
.menu .menu-item a {
    font-size: 15px;
	border-bottom: none;
}
// 菜单各项边距
.menu .menu-item {
    margin: 5px 15px;
}
// 菜单超链接样式
.menu .menu-item a:hover {
    color: rgb(161, 102, 171);
    border-bottom: none;
}
//文章样式
.post {
    margin-bottom: 70px;
    padding: 2em 64px;
    box-shadow: 0px 0px 10px 0px rgba(0,0,0,0.5);
    background-color: #fff;
}
// 文章标题字体
.posts-expand .post-title {
    //font-size: 26px;
	color: #000;
    font-weight: 700;
	margin: 20px 0 15px;
    text-align: center;
}
// 文章标题动态效果
.posts-expand .post-title-link::before {
    background-image: linear-gradient(90deg, #A166AB 0%, #A166AB 25%, #A166AB 50%, #A166AB 75%, #A166AB 100%);
}
// 文章元数据（meta）留白更改
.posts-expand .post-meta {
    margin: 10px 0px 20px 0px;
	line-height: 24px;
}
// 文章的描述description
.posts-expand .post-meta .post-description {
    font-size: 14px;
    margin-top: 30px;
    margin-bottom: 30px;
    color: #666;
	border: 0px solid #666;
    padding: 0 0 20px 0;
    border-bottom-width: 1px;
}
// 去除在页面文章之间的分割线
.posts-expand .post-eof {
    margin: 0px;
    background-color: rgba(255, 255, 255, 0);
}
.pagination {
    border: none;
    margin: 0px;
    margin-top: 0px;
    margin-right: 0px;
    margin-bottom: 40px;
    margin-left: 0px;
}
// 页面底部页码
.pagination .page-number.current {
    color: #222;
    border-radius: 100%;
    box-shadow: 0px 0px 10px 0px rgba(0, 0, 0, 0.5);
    background-color: rgba(255, 255, 255, 0.35);
}
.pagination .prev, .pagination .next, .pagination .page-number {
    margin-bottom: 10px;
    border: none;
}
.pagination .space {
    color: #222;
}
// 页面底部页脚
.footer {
    line-height: 1.5;
    background-color: rgba(255, 255, 255, 0.75);
    color: #333;
    border-top-width: 3px;
    border-top-style: solid;
    border-top-color: rgb(161, 102, 171);
    box-shadow: 0px -10px 10px 0px rgba(0, 0, 0, 0.15);
	font-size: 16px;
}
// 文章底部的tags
.posts-expand .post-tags a {
    border-bottom: none;
    margin-right: 0px;
    font-size: 13px;
    padding: 0px 5px;
    border-radius: 3px;
    transition-duration: 0.2s;
    transition-timing-function: ease-in-out;
    transition-delay: 0s;
}
.posts-expand .post-tags a:hover {
    background: #eee;
}
// 文章底部留白更改
.post-widgets {
    padding-top: 0px;
}
.post-nav {
    margin-top: 30px;
}
// 文章底部页面跳转
.post-nav-item a {
    color: rgb(80, 115, 184);
    font-weight: bold;
}
.post-nav-item a:hover {
    color: rgb(161, 102, 171);
    font-weight: bold;
}
// 超链接样式
.post-body a {
    color: rgb(80, 115, 184);
    border-bottom: none;
    &:hover {
      color: rgb(161, 102, 171);
      text-decoration: underline;
    }
}
.posts-expand .post-meta a, .post-copyright a {
    color: rgb(80, 115, 184);
    border-bottom: none;
    &:hover {
      color: rgb(161, 102, 171);
      text-decoration: underline;
    }
}
a {
    color: rgb(80, 115, 184);
    border-bottom-color: rgb(80, 115, 184);
}
a:hover {
    color: rgb(161, 102, 171);
    border-bottom-color: rgb(161, 102, 171);
}
//修复下载按钮超链接样式



// 分割线样式
hr {
    margin: 10px 0px 30px 0px;
}
// 文章内标题样式（左边的竖线）
.post-body h2, h3, h4, h5, h6 {
    border-left: 4px solid rgb(161, 102, 171);
    margin-left: -64px;
    padding-left: 60px;
}
// 文章内标题大小（v7.2.0后的版本字体偏大）
h2 {
    font-size: 24px;
}
h3 {
    font-size: 22px;
}
h4 {
    font-size: 20px;
}
h5 {
    font-size: 18px;
}
h6 {
    font-size: 16px;
}
// 文章```代码块顶部样式（night主题）
.highlight figcaption {
    background: #1d1f21;
    border-bottom: 1px solid #1d1f21;
	font-family: consolas, EB Garamond, Noto Serif SC, sans-serif;
	font-size: 14px;
}

// 文章``代码块的自定义样式
code {
    //color: #c7254e;
    //background: #f9f2f4;
	margin: 0px 4px;
    //border: 1px solid #d6d6d6;
	//font-size: 14px;
}
// 文章```代码块复制mac样式
.highlight-wrap {
    box-shadow: 0 5px 20px 0 rgba(0,0,0,0.4);
}
// 文章```代码块diff样式
pre .addition {
    background: none;
	//color: #00aa00;
	color: #a6e22e;
}
pre .deletion {
    background: none;
	//color: #aa0000;
    color: #f92672;
}
// 时间轴样式
.posts-collapse {
    margin: 80px 0 70px 0;
	background-color: #fff;
    box-shadow: 0px 0px 10px 0px rgba(0,0,0,0.5);
	padding: 2em 4em;
}
.posts-collapse .post {
	padding: 0px;
	box-shadow: none;
}
//加油词
.page-archive .posts-collapse .archive-page-counter {
    left: 0px;
}
//时间轴第一个圆点
.page-archive .posts-collapse .archive-move-on{
    opacity: 0;
}
//时间轴年份
.posts-collapse .collection-title h1, .posts-collapse .collection-title h2 {
    margin-left: 0;
}
.posts-collapse .collection-title::before {
    margin: 10px 0 30px 0;
    content: none;
}
//时间轴年份圆点
.posts-collapse .collection-year::before {
    content: none;
    }

//时间轴写作时间
.posts-collapse .post-meta {
    font-size: 1.125em;
	left: unset;
    right: 0px;
    position: absolute;
    top: 0px;
}
//时间轴色带
.posts-collapse::after{
    content: none;
}
// 时间轴文章标题左边圆点颜色
.posts-collapse .post-header:hover::before {
    background-color: rgb(161, 102, 171);
}
// 时间轴文章标题
.posts-collapse .post-title a {
    color: rgb(80, 115, 184);
	font-size: 1.2em;
	position: relative;
    left: -30px;
}
.posts-collapse .post-title a:hover {
    color: rgb(161, 102, 171);
}
// 时间轴文章标题底部虚线
.posts-collapse .post-header:hover {
    border-bottom-color: rgb(161, 102, 171);
}

// 白色背景
.post-block.page {
    margin: 0px 0px 75px 0px;
    background-color: rgb(255, 255, 255);
	box-shadow: 0px 0px 10px 0px rgba(0, 0, 0, 0.5);
	padding: 2em 64px;
}
// 移动端样式

@media (max-width: 767px) {
    .header-inner {
        padding-left: 0;
        padding-bottom: 0px;
        padding-right: 0;
        padding-top: 0px;
    }

    .container .main-inner {
        margin-top: 30px;
    }

	.posts-collapse {
	    .post-title a {
		    font-size: 1em;
		}
		.post-meta {
		    font-size: 0.875em;
		}
		.post {
			padding: 0 !important;
		}
		padding: 2em 15px 1em 15px;
		margin: 70px 0 70px 0;
	}
	.post-block.page {
        padding: 32px 15px 32px 15px !important;
    }
	.post-body h2, h3, h4, h5, h6 {
        margin-left: -15px;
		padding-left: 15px;
    }
    .posts-expand {
        margin: 0px;
        padding-top: 70px;
    }
    .posts-expand .post-title {
        font-size: 22px;
    }
    .posts-expand .post-meta {
        font-size: 12px;
    }
    .post {
        margin-bottom: 55px !important;
        padding: 32px 15px 32px 15px !important;
    }
    .posts-expand .post-tags {
        margin-top: 10px;
    }
    .post-widgets {
        margin-top: 10px;
    }
    .comments {
        //margin: 40px 0px 40px 0px !important;
    }
	.pagination {
        margin-bottom: 15px;
		margin-top: -30px;
    }
    .footer {
        box-shadow: 0px -5px 10px 0px rgba(0, 0, 0, 0.5);
    }
}

.posts-expand .home .post-title, .posts-expand .home .post-meta {
    text-align: center;
    }
// 移动端侧栏动态
@media (max-width: 767px){
    .sidebar-active + #sidebar-dimmer {
        opacity: 0;
    }
}

// 移动端左上角菜单按钮
.site-nav-toggle {
    top: 35px;
    left: 10px;
    position: absolute;
}
.btn-bar {
    background-color: rgb(255, 255, 255);
}
@media (max-width: 767px) {
    .menu {
        text-align: center;
        box-shadow: 0px 5px 10px 0px rgba(0, 0, 0, 0.5);
    }
    .site-nav {
        top: initial;
        background-color: rgba(255, 255, 255, 0.75);
        border-top: none;
        border-bottom: none;
        position: relative;
        z-index: 1024;
        transform: none;
    }
}
// 移动端顶部
@media (max-width: 767px) {
    .site-title {
        font-size: 35px !important;
        letter-spacing: 0px !important;
    }
    .site-subtitle{
        letter-spacing: 0px !important;
        padding-bottom: 0px !important;
    }

    .menu .menu-item {
        margin: 0px 10px !important;
    }
}

.site-brand-container {
    position: relative;

}


.symbolic-animals {
  display: inline-block;
  font: normal normal normal 14px/1 chinese-zodiac;
  font-size: inherit;
  text-rendering: auto;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}
.icon-dragon:before { content: '\e806'; font-size: 35px;}
.icon-tiger:before { content: '\e809'; font-size: 35px;}
.icon-pig:before { content: '\e810'; font-size: 35px;}
.icon-horse:before { content: '\e813'; font-size: 35px;}
.icon-rat:before { content: '\e816'; font-size: 35px;}
.icon-goat:before { content: '\e818'; font-size: 35px;}
