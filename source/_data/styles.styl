// Custom styles.

//页面背景
body {
	//background: #f5f7f9;
    background-image: linear-gradient(to left , #fff1eb 0%, #ace0f9 100%);
}

main {
	flex: 1;
}


//首页文章样式
.home  {
    margin-bottom: 70px;
    padding: 2em 64px;
    box-shadow: 0px 0px 10px 0px rgba(0,0,0,0.5);
    background-color: #ffffff;
    -webkit-box-shadow: 0px 0px 10px 0px rgba(0,0,0,0.5);
    -moz-box-shadow:  0px 0px 10px 0px rgba(0,0,0,0.5);
}


//头像旋转
.ds-top-threads li a:hover {
    border-left: 8px solid #4d768c;
}
//首页头部样式
.header {
	height: 150px;
    background-repeat: no-repeat;
    background-image: linear-gradient(25deg, #14dfe2, #8adbc3, #bbd7a5, #dfd385)

}

.site-meta img {
    max-height: 100px;
    }

//更改display为block，使标题独占居中
.header-inner {
  position: relative;
  display: block;
  width: 100%;
}



.site-meta {
    float: none;
    margin-left: 0px;
    text-align: center;
	padding-bottom: 24px;
}
.menu {
    float: none;
}
.logo-line-before,
.logo-line-after {
    display: none;
}
.menu .menu-item a {
    font-size: 14px;
    color: rgb(15, 46, 65);
    border-radius: 4px;
}

.site-meta .site-title {
    font-size: 40px;
    color: #f37055;
}

// button
.post-button {
    text-align: center;
}

.post-button .btn {
    color: #555 !important;
    background-color: rgb(255, 255, 255);
    border-radius: 3px;
    font-size: 15px;
    box-shadow: inset 0px 0px 10px 0px rgba(0, 0, 0, 0.35);
    border: none !important;
    transition-property: unset;
    padding: 0px 15px;
}
.post-button .btn:hover {
    color: rgb(255, 255, 255) !important;
    border-radius: 3px;
    font-size: 15px;
    box-shadow: inset 0px 0px 10px 0px rgba(0, 0, 0, 0.35);
    background-image: linear-gradient(to right, #aa96da, #facad3);
}
.post-meta  {
    text-align: center;
    }



//首页尾部样式
.footer-inner {
    font-family: 'Noto Serif SC';
    font-weight: bold;
    text-align: center;
    color: #4c618f;
}
//侧边栏信息样式修改
.site-author-name {
    margin: 10px 0 0;
    color: #090909;
    font-family: 'Mansalva', sans-serif;
}
.links-of-blogroll {
    font-size: 14px;
    margin-bottom: 42px;
}
.links-of-author {
    margin-top: 30px;
    margin-bottom: 58px;
}
.sidebar-inner {
    color: #649ab6;
	height: auto;
}

.sidebar {
  /* background-size: 240px 499px; */
  background-position-y: 1vh;
  background-color: #f5f7f9;
  box-shadow: inset 2px 2px 40px #bdb2b2;
  background-image: url("https://picsshine.oss-cn-shenzhen.aliyuncs.com/blogpics/夏目2.jpg");
  background-repeat: no-repeat;
  background-position: left;
}

.sidebar a {
    color: #649ab6;
    border-bottom-color: #649ab6;
    border-bottom: none;
}
.sidebar a:hover {
    color: #0c0b0b;
}
.site-state-item {
    display: inline-block;
    padding: 8px 20px;
    border-left: 1px solid #649ab6;
}
.sidebar-nav .sidebar-nav-active {
    color: #649ab6;
    border-bottom-color: #649ab6;
}
.sidebar-nav li:hover {
    color: #0c0b0b;
}
//侧栏按钮样式
.sidebar-toggle {
    background: #649ab6;
}
.back-to-top {
    background: #649ab6;
}
// Custom styles.
// 字体
.post-body {
    color: #000;
}


// 自定义的引用样式
blockquote.question {
    color: #555;
    border-left: 4px solid rgb(16, 152, 173);
    background-color: rgb(227, 242, 253);
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
    margin-bottom: 20px;
}
// 自定义的数字块
span#inline-toc {
    display: inline-block;
    border-radius: 80% 100% 90% 20%;
    background-color: rgb(227, 242, 253);
    color: #555;
    padding: 0.05em 0.4em;
    margin: 2px 5px 2px 0px;
    line-height: 1.5;
}
//自定义note标识
.alert {
    padding: 15px;
    margin-bottom: 20px;
    border: 1px solid transparent;
    border-radius: 4px;
}
.alert-success {
    color: #468847;
    background-color: #dff0d8;
    border-color: #d6e9c6;
}
.alert-info {
    color: #3a87ad;
    background-color: #e2eaee;
    border-color: #c5d5dd;
}
.alert-warning {
    color: #c09853;
    background-color: #fcf8e3;
    border-color: #faebcc;
}
.alert-danger {
    color: #b94a48;
    background-color: #f2dede;
    border-color: #ebccd1;
}
//自定义文字背景色块
