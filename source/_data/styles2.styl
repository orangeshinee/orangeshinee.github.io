// Custom styles.

//页面背景
body {
	//background: #f5f7f9;
    background-image: linear-gradient(to left , #fff1eb 0%, #ace0f9 100%);
    
}



//首页文章样式
.post  {
    // padding: 2em 64px;
    box-shadow: 0px 0px 10px 0px rgba(0,0,0,0.5);
    background-color: #fff;
}

a:hover {
  color: #f9a972;
  border-bottom-color: #f9a972;
}



.post-body {
    font-size: 1em;
    }


//头像旋转
.ds-top-threads li a:hover {
    border-left: 8px solid #4d768c;
}

// 头部
.menu .menu-item a:hover,
.menu-item-active a {
  border-bottom-color: #f9a972;
}
.sidebar a:hover,
.sidebar .exturl:hover {
  color: #f9a972;
}
.sidebar-nav li:hover {
  color: #fc6423;
}
.sidebar-nav .sidebar-nav-active:hover {
  color: #fc6423;
}
.menu .menu-item a:hover,
.menu-item-active a {
  background: #f9f9f9;
  border-bottom-color: #fff;
}
.site-meta:hover {
  background: rgba(0,0,0,0.9);
  border-radius: 0 0 70px 70px;
  box-shadow: 0 8px 20px -3px rgba(0,0,0,0.6);
}
.site-meta {
    background: rgba(0,0,0,0.8);
    border-radius: 0 0 0 0;
    box-shadow: 0 2px 15px 0 rgba(0,0,0,0.6);
    transition: all 0.2s linear;
}
.menu .menu-item a:hover, .menu-item-active a {
  background: rgba(255,255,255,0.5);
  border-radius: 50px 0 0 50px;
  border-color: transparent;
  box-shadow: 0 8px 20px -8px rgba(0,0,0,0.3);
  font-size: 15px;
}
.menu-item-active a:after {
  content: " ";
  position: absolute;
  top: 50%;
  margin-top: -3px;
  right: 15px;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background-color: #f9a972;
}
// 首页文章标题 下划线颜色
.posts-expand .post-title-link::before {
    background-color: #f9a972;
}

//阿里图标
.icon {
       width: 20px; height: 20px;
       vertical-align: -4.5px;
       fill: currentColor;
       overflow: hidden;
    margin-left: 10px;
    margin-right: 15px;
}


//主页面调整
.header-inner {
    background: rgba(255,255,255,0.75);
    border-radius: 0 0 10px 10px;
    box-shadow: 0 8px 20px -8px rgba(0,0,0,0.3);
}

.sidebar {   
    background: transparent;
}

.sidebar-inner {
    background: rgba(255,255,255,0.75);
    border-radius: 10px;
    box-shadow: 0 8px 20px -8px rgba(0,0,0,0.3);
}

.header {
    width: 960px
}

.container .main-inner {
    width: 960px;
    margin: 0 auto;
}

.site-title img {
    max-width: 80%;
    }

.content-wrap {
    background: rgba(255,255,255,0.9);
    border-radius: 0 0 10px 10px;
    box-shadow: 0 8px 20px -8px rgba(0,0,0,0.3);
    margin-bottom: 50px;
    min-height: 800px;
}


// 移动端主页
@media (max-width: 991px){
.container .main-inner {
    width: 100%;
}

.site-title img {
    max-width: 60%;
    }

.header-inner {
    left: 0;
}
}

// 侧栏 aside
.links-of-author {
  justify-content: end;
}