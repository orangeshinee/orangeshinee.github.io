.footer {
  color: $grey-dark;
  font-size: $font-size-small;

  &.footer-fixed {
    bottom: 0;
    left: 0;
    position: absolute;
    right: 0;
  }

  img {
    border: 0;
  }
}

.footer-inner {
  text-align: center;
}

@keyframes iconAnimate {
  0%, 100% {
    transform: scale(1);
  }

  10%, 30% {
    transform: scale(.9);
  }

  20%, 40%, 60%, 80% {
    transform: scale(1.1);
  }

  50%, 70% {
    transform: scale(1.1);
  }
}



.powered-by, .theme-info {
  display: inline-block;
}
